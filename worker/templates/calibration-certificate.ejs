<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Calibration Certificate</title>
  <style>
    @page { size: A4; margin: 15mm 14mm 15mm 12mm; }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 10pt;
      color: #000;
      overflow: hidden;
    }

    /* ── Page break ── */
    .page { page-break-after: always; }
    .page:last-child { page-break-after: auto; }

    /* ── Header ── */
    .header {
      display: flex;
      align-items: flex-start;
      margin-bottom: 6px;
    }
    .header-logo {
      width: 170px;
      flex-shrink: 0;
      text-align: center;
    }
    .header-logo img {
      height: 100px;
      width: auto;
    }
    .header-company {
      flex: 1;
      padding: 4px 12px 0;
      line-height: 1.5;
    }
    .header-company .company-name {
      font-size: 19pt;
      font-weight: 700;
      color: #0a2351;
      font-family: 'Times New Roman', Times, serif;
      margin-bottom: 1px;
    }
    .header-company .company-meta {
      font-size: 8.5pt;
      color: #000;
      line-height: 1.7;
    }
    .header-company .company-meta .email-website-row {
      display: flex;
      justify-content: flex-start;
      gap: 0;
    }
    .header-company .company-meta .email-website-row .website {
      margin-left: auto;
    }
    .header-qr {
      width: 90px;
      flex-shrink: 0;
      display: flex;
      align-items: flex-start;
      justify-content: flex-end;
      padding-top: 4px;
    }
    .header-qr img {
      height: 82px;
      width: 82px;
      object-fit: contain;
    }

    hr.divider {
      border: none;
      border-top: 2px solid #000;
      margin: 6px 0 10px;
    }

    /* ── Certificate title ── */
    .cert-title {
      text-align: center;
      font-size: 13pt;
      font-weight: 700;
      text-decoration: underline;
      letter-spacing: 1px;
      margin-bottom: 10px;
    }

    /* ── All tables — RIGHT BORDER FIX ── */
    table {
      width: calc(100% - 1px);
      border-collapse: collapse;
      table-layout: fixed;
      margin-bottom: 0;
      border: 1px solid #000;
    }

    table td, table th {
      border: 1px solid #000;
      padding: 5px 7px;
      vertical-align: middle;
      font-size: 9.5pt;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .bold { font-weight: 700; }
    .center { text-align: center; }
    .italic { font-style: italic; }

    /* ── Results table ── */
    .results-table th {
      background: #f0f0f0;
      text-align: center;
      font-weight: 700;
      font-size: 9pt;
    }
    .results-table td {
      text-align: center;
      font-size: 9pt;
    }
    .results-table td.param-cell {
      font-weight: 600;
    }

    /* ── Section label above table ── */
    .section-label {
      font-weight: 700;
      font-size: 9.5pt;
      margin: 8px 0 4px;
    }

    /* ── Calibration type heading ── */
    .cal-type-heading {
      text-align: center;
      font-weight: 700;
      font-size: 10pt;
      border: 1px solid #000;
      padding: 5px;
      margin-bottom: 0;
      width: calc(100% - 1px);
    }

    /* ── Signature footer ── */
    .signature-footer {
      margin-top: 30px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      width: calc(100% - 1px);
    }
    .signature-block {
      text-align: center;
      width: 40%;
    }
    .signature-img {
      height: 60px;
      width: auto;
      margin-bottom: 4px;
    }
    .stamp-block {
      text-align: center;
      width: 20%;
    }
    .stamp-img {
      height: 70px;
      width: auto;
    }
    .signature-name {
      font-weight: 700;
      font-size: 10pt;
      margin-top: 4px;
    }
    .signature-role {
      font-size: 9pt;
      border-top: 1px solid #000;
      padding-top: 4px;
      margin-top: 2px;
    }
    .doc-ref {
      text-align: right;
      font-size: 8pt;
      font-weight: 700;
      margin-top: 10px;
    }
  </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════════ PAGE 1 -->
<div class="page">

  <!-- Header -->
  <div class="header">
    <div class="header-logo">
      <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="Josts Logo" />
      <% } %>
    </div>
    <div class="header-company">
      <div class="company-name">Jost&#8217;s Engineering Company Limited</div>
      <div class="company-meta">
        19, British Indian Street, Kolkata 700 069, West Bengal, India.<br/>
        CIN: L28100MH1907PLC000252, Tel: +91 33 2242 9510, Fax: +91 33 2248 0861<br/>
        <span class="email-website-row">
          <span>Email: salescal@josts.in</span>
          <span class="website">Website: www.josts.com</span>
        </span>
        <em>(Registered Office: Great Social Building, 60 Sir Phirozeshah Mehta Road, Mumbai 400 001)</em>
      </div>
    </div>
    <div class="header-qr">
      <% if (typeof qrCodeUrl !== 'undefined' && qrCodeUrl) { %>
        <img src="<%= qrCodeUrl %>" alt="QR Code" />
      <% } %>
    </div>
  </div>

  <hr class="divider" />

  <!-- Certificate title -->
  <div class="cert-title">CALIBRATION CERTIFICATE</div>

  <!-- ── Certificate No / Issue Date / Page ── -->
  <table>
    <tr>
      <td colspan="3" class="center bold" style="width:55%">Certificate No.</td>
      <td colspan="2" class="center bold" style="width:30%">Certificate Issue Date</td>
      <td class="center bold" style="width:15%">Page<br/>Number</td>
    </tr>
    <tr>
      <td colspan="3" class="center"><%= typeof certificateNo !== 'undefined' ? certificateNo : '' %></td>
      <td colspan="2" class="center"><%= typeof certificateIssueDate !== 'undefined' ? certificateIssueDate : '' %></td>
      <td class="center">1 of <%= typeof totalPages !== 'undefined' ? totalPages : '2' %></td>
    </tr>
  </table>

  <!-- ── Dates / Customer Ref ── -->
  <table>
    <tr>
      <td class="bold center" style="width:15%">DUC<br/>Received<br/>Date</td>
      <td class="bold center" style="width:16%">Date of<br/>Calibration</td>
      <td class="bold center" style="width:16%">Valid<br/>Up To</td>
      <td class="bold center" colspan="3">Customer Reference No.</td>
    </tr>
    <tr>
      <td class="center"><%= typeof ducReceivedDate !== 'undefined' ? ducReceivedDate : '' %></td>
      <td class="center"><%= typeof dateOfCalibration !== 'undefined' ? dateOfCalibration : '' %></td>
      <td class="center"><%= typeof validUpto !== 'undefined' ? validUpto : '' %></td>
      <td class="center" colspan="3"><%= typeof customerReferenceNo !== 'undefined' ? customerReferenceNo : '' %></td>
    </tr>
  </table>

  <!-- ── Customer Name & Address ── -->
  <table>
    <tr>
      <td class="bold" style="width:30%">Name &amp; Address of the Customer :</td>
      <td style="white-space:pre-line"><%= typeof customerAddress !== 'undefined' ? customerAddress : '' %></td>
    </tr>
  </table>

  <!-- ── DUC Details header ── -->
  <table>
    <tr>
      <td colspan="7" class="bold center">Details of the DUC to be Calibrated</td>
    </tr>
    <tr>
      <td class="bold center" colspan="2">Name of DUC</td>
      <td class="bold center">Identification /<br/>Serial Number</td>
      <td class="bold center">Make</td>
      <td class="bold center">Model</td>
      <td class="bold center">Range</td>
      <td class="bold center">Least Count</td>
    </tr>
    <tr>
      <td colspan="2" class="center"><%= typeof ducName !== 'undefined' ? ducName : '' %></td>
      <td class="center"><%= typeof ducSerialNo !== 'undefined' ? ducSerialNo : '' %></td>
      <td class="center"><%= typeof ducMake !== 'undefined' ? ducMake : '' %></td>
      <td class="center"><%= typeof ducModel !== 'undefined' ? ducModel : '' %></td>
      <td class="center"><%= typeof ducRange !== 'undefined' ? ducRange : 'As Per Instrument Spec.' %></td>
      <td class="center"><%= typeof ducLeastCount !== 'undefined' ? ducLeastCount : 'Refer Cal Results' %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Accuracy :</td>
      <td colspan="5"><%= typeof accuracy !== 'undefined' ? accuracy : "As per Manufacturer's Specification" %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Condition of Item :</td>
      <td colspan="5"><%= typeof conditionOfItem !== 'undefined' ? conditionOfItem : 'Satisfactory' %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Location of Calibration:</td>
      <td colspan="5"><%= typeof locationOfCalibration !== 'undefined' ? locationOfCalibration : 'At Site' %></td>
    </tr>
  </table>

  <!-- ── Environmental Conditions ── -->
  <table>
    <tr>
      <td colspan="6" class="bold center">Environmental Condition</td>
    </tr>
    <tr>
      <td rowspan="2" class="bold center" style="width:18%">Recommended</td>
      <td style="width:14%">Temp</td>
      <td style="width:14%"><%= typeof recommendedTemp !== 'undefined' ? recommendedTemp : '25±4 °C' %></td>
      <td rowspan="2" class="bold center" style="width:12%">During<br/>Calibration</td>
      <td style="width:14%">Temp</td>
      <td><%= typeof duringCalibrationTemp !== 'undefined' ? duringCalibrationTemp : '' %></td>
    </tr>
    <tr>
      <td>Humidity</td>
      <td><%= typeof recommendedHumidity !== 'undefined' ? recommendedHumidity : '55±15 %' %></td>
      <td>Humidity</td>
      <td><%= typeof duringCalibrationHumidity !== 'undefined' ? duringCalibrationHumidity : '' %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Calibration Procedure :</td>
      <td colspan="2"><%= typeof calibrationProcedure !== 'undefined' ? calibrationProcedure : '' %></td>
      <td class="bold">Method of Calibration :</td>
      <td><%= typeof methodOfCalibration !== 'undefined' ? methodOfCalibration : 'Direct Method' %></td>
    </tr>
  </table>

  <!-- ── Description of Standards ── -->
  <table>
    <tr>
      <td colspan="4" class="italic">
        <strong>Description of Standard (s) :</strong>
        <%= typeof descriptionOfStandards !== 'undefined' ? descriptionOfStandards : 'Traceable to National / International Standards' %>
      </td>
    </tr>
  </table>

  <!-- ── Reference Standard Details ── -->
  <table>
    <tr>
      <td class="bold center" style="width:28%">Reference Standard Details</td>
      <td class="bold center" style="width:18%">Make/Model</td>
      <td class="bold center" style="width:16%">Valid upto</td>
      <td class="bold center">Traceability Certificate No.</td>
    </tr>
    <% if (typeof referenceStandards !== 'undefined' && referenceStandards && referenceStandards.length) { %>
      <% referenceStandards.forEach(function(std) { %>
        <tr>
          <td>Name : <%= std.name || '' %></td>
          <td class="center" style="border-bottom: hidden;"><%= std.makeModel || '' %></td>
          <td class="center" style="border-bottom: hidden;"><%= std.validUpto || '' %></td>
          <td class="center" style="border-bottom: hidden;"><%= std.traceabilityCertNo || '' %></td>
        </tr>
        <tr>
          <td>ID No : <%= std.idNo || '' %></td>
          <td style="border-top: hidden; border-bottom: hidden;"></td>
          <td style="border-top: hidden; border-bottom: hidden;"></td>
          <td style="border-top: hidden; border-bottom: hidden;"></td>
        </tr>
        <tr>
          <td>Sr No : <%= std.srNo || '' %></td>
          <td style="border-top: hidden;"></td>
          <td style="border-top: hidden;"></td>
          <td style="border-top: hidden;"></td>
        </tr>
      <% }); %>
    <% } else { %>
      <tr>
        <td>Name :</td>
        <td class="center" style="border-bottom: hidden;"></td>
        <td class="center" style="border-bottom: hidden;"></td>
        <td class="center" style="border-bottom: hidden;"></td>
      </tr>
      <tr>
        <td>ID No :</td>
        <td style="border-top: hidden; border-bottom: hidden;"></td>
        <td style="border-top: hidden; border-bottom: hidden;"></td>
        <td style="border-top: hidden; border-bottom: hidden;"></td>
      </tr>
      <tr>
        <td>Sr No :</td>
        <td style="border-top: hidden;"></td>
        <td style="border-top: hidden;"></td>
        <td style="border-top: hidden;"></td>
      </tr>
    <% } %>
  </table>

  <!-- ── Signature Footer (Page 1) ── -->
  <div class="signature-footer">
    <div class="signature-block">
      <% if (typeof calibratedBySignatureUrl !== 'undefined' && calibratedBySignatureUrl) { %>
        <img class="signature-img" src="<%= calibratedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof calibratedByName !== 'undefined' ? calibratedByName : 'Debasish Roy' %></div>
      <div class="signature-role">Calibrated By : <%= typeof calibratedByRole !== 'undefined' ? calibratedByRole : 'Calibration Engineer' %></div>
    </div>
    <div class="stamp-block">
      <% if (typeof stampUrl !== 'undefined' && stampUrl) { %>
        <img class="stamp-img" src="<%= stampUrl %>" alt="Company Stamp" />
      <% } else { %>
        <div style="height:70px;"></div>
      <% } %>
    </div>
    <div class="signature-block">
      <% if (typeof approvedBySignatureUrl !== 'undefined' && approvedBySignatureUrl) { %>
        <img class="signature-img" src="<%= approvedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof approvedByName !== 'undefined' ? approvedByName : 'Santi Pada Sinha' %></div>
      <div class="signature-role">Approved By : <%= typeof approvedByRole !== 'undefined' ? approvedByRole : 'Technical/Quality Manager' %></div>
    </div>
  </div>
  <div class="doc-ref"><%= typeof docRef !== 'undefined' ? docRef : 'JECL/KOL/LAB/43B' %></div>

</div>
<!-- ═══════════════════ END PAGE 1 ════════════════════════════════════════════ -->


<!-- ═══════════════════════════════════════════════════════════════════ PAGE 2 -->
<div class="page">

  <!-- Header -->
  <div class="header">
    <div class="header-logo">
      <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="Josts Logo" />
      <% } %>
    </div>
    <div class="header-company">
      <div class="company-name">Jost&#8217;s Engineering Company Limited</div>
      <div class="company-meta">
        19, British Indian Street, Kolkata 700 069, West Bengal, India.<br/>
        CIN: L28100MH1907PLC000252, Tel: +91 33 2242 9510, Fax: +91 33 2248 0861<br/>
        <span class="email-website-row">
          <span>Email: salescal@josts.in</span>
          <span class="website">Website: www.josts.com</span>
        </span>
        <em>(Registered Office: Great Social Building, 60 Sir Phirozeshah Mehta Road, Mumbai 400 001)</em>
      </div>
    </div>
    <div class="header-qr">
      <% if (typeof qrCodeUrl !== 'undefined' && qrCodeUrl) { %>
        <img src="<%= qrCodeUrl %>" alt="QR Code" />
      <% } %>
    </div>
  </div>

  <hr class="divider" />

  <!-- Certificate No / Issue Date / Page (repeated on page 2) -->
  <table>
    <tr>
      <td colspan="3" class="center bold" style="width:55%">Certificate No.</td>
      <td colspan="2" class="center bold" style="width:30%">Certificate Issue Date</td>
      <td class="center bold" style="width:15%">Page<br/>Number</td>
    </tr>
    <tr>
      <td colspan="3" class="center"><%= typeof certificateNo !== 'undefined' ? certificateNo : '' %></td>
      <td colspan="2" class="center"><%= typeof certificateIssueDate !== 'undefined' ? certificateIssueDate : '' %></td>
      <td class="center">2 of <%= typeof totalPages !== 'undefined' ? totalPages : '2' %></td>
    </tr>
  </table>

  <!-- ── Calibration Results section ── -->
  <div class="section-label">Calibration Results :</div>

  <!-- Calibration type banner -->
  <div class="cal-type-heading">
    <%= typeof calibrationType !== 'undefined' ? calibrationType : 'Electro - Technical Calibration' %>
  </div>

  <!-- Results table -->
  <table class="results-table">
    <thead>
      <tr>
        <th rowspan="2" style="width:16%">Parameter</th>
        <th rowspan="2" style="width:14%">Range</th>
        <th colspan="2">STANDARD</th>
        <th colspan="2">DUC</th>
        <th colspan="2">ERROR</th>
        <th rowspan="2" style="width:14%">Expanded<br/>Uncertainty (± %)</th>
      </tr>
      <tr>
        <th style="width:8%">Value</th>
        <th style="width:6%">Unit</th>
        <th style="width:8%">Value</th>
        <th style="width:6%">Unit</th>
        <th style="width:8%">Value</th>
        <th style="width:6%">Unit</th>
      </tr>
    </thead>
    <tbody>
      <% if (typeof calibrationResults !== 'undefined' && calibrationResults && calibrationResults.length) { %>
        <% calibrationResults.forEach(function(param) { %>
          <%
            // Count total rows for this parameter (rowspan)
            var totalRows = 0;
            (param.ranges || []).forEach(function(r) { totalRows += (r.rows || []).length; });
            var firstRow = true;
          %>
          <% (param.ranges || []).forEach(function(range) { %>
            <% (range.rows || []).forEach(function(row, rowIdx) { %>
              <tr>
                <% if (firstRow) { firstRow = false; %>
                  <td class="param-cell center" rowspan="<%= totalRows %>"><%= param.parameter || '' %></td>
                <% } %>
                <% if (rowIdx === 0) { %>
                  <td class="center" rowspan="<%= (range.rows || []).length %>"><%= range.label || '' %></td>
                <% } %>
                <td class="center"><%= row.standardValue || '' %></td>
                <td class="center"><%= row.standardUnit  || '' %></td>
                <td class="center"><%= row.ducValue       || '' %></td>
                <td class="center"><%= row.ducUnit        || '' %></td>
                <td class="center"><%= row.errorValue     || '' %></td>
                <td class="center"><%= row.errorUnit      || '' %></td>
                <td class="center"><%= row.expandedUncertainty || '' %></td>
              </tr>
            <% }); %>
          <% }); %>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="9" class="center" style="color:#888;font-style:italic">No calibration results provided</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <!-- ── Signature Footer (Page 2) ── -->
  <div class="signature-footer">
    <div class="signature-block">
      <% if (typeof calibratedBySignatureUrl !== 'undefined' && calibratedBySignatureUrl) { %>
        <img class="signature-img" src="<%= calibratedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof calibratedByName !== 'undefined' ? calibratedByName : 'Debasish Roy' %></div>
      <div class="signature-role">Calibrated By : <%= typeof calibratedByRole !== 'undefined' ? calibratedByRole : 'Calibration Engineer' %></div>
    </div>
    <div class="stamp-block">
      <% if (typeof stampUrl !== 'undefined' && stampUrl) { %>
        <img class="stamp-img" src="<%= stampUrl %>" alt="Company Stamp" />
      <% } else { %>
        <div style="height:70px;"></div>
      <% } %>
    </div>
    <div class="signature-block">
      <% if (typeof approvedBySignatureUrl !== 'undefined' && approvedBySignatureUrl) { %>
        <img class="signature-img" src="<%= approvedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof approvedByName !== 'undefined' ? approvedByName : 'Santi Pada Sinha' %></div>
      <div class="signature-role">Approved By : <%= typeof approvedByRole !== 'undefined' ? approvedByRole : 'Technical/Quality Manager' %></div>
    </div>
  </div>
  <div class="doc-ref"><%= typeof docRef !== 'undefined' ? docRef : 'JECL/KOL/LAB/43B' %></div>

</div>
<!-- ═══════════════════ END PAGE 2 ════════════════════════════════════════════ -->

</body>
</html>
