<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Calibration Certificate</title>
  <style>
    @page { size: A4; margin: 15mm 14mm 15mm 12mm; }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 10pt;
      color: #000;
      overflow: hidden;
    }

    /* ── Page layout: fixed A4 height so header/footer stay pinned ── */
    .page {
      display: flex;
      flex-direction: column;
      height: 267mm; /* A4 297mm − top 15mm − bottom 15mm */
      page-break-after: always;
      overflow: hidden;
    }
    .page:last-child { page-break-after: auto; }

    /* Middle content grows to fill space between header and footer */
    .page-body { flex: 1; }

    /* ── Header ── */
    .header {
      display: flex;
      align-items: flex-start;
      margin-bottom: 4px;
      gap: 0;
    }
    .header-logo {
      width: 155px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-right: 10px;
    }
    .header-logo img {
      height: 160px;
      width: auto;
    }
    .header-company {
      flex: 1;
      padding: 0 12px;
    }
    .header-company .company-name {
      font-size: 18pt;
      font-weight: 700;
      color: #0a2351;
      font-family: Arial, Helvetica, sans-serif;
      margin-bottom: 6px;
      line-height: 1.2;
    }
    .header-company .company-meta {
      font-size: 8.5pt;
      color: #000;
      line-height: 1.55;
    }
    .header-company .company-meta .meta-row {
      display: flex;
      justify-content: space-between;
    }
    .header-qr {
      width: 90px;
      flex-shrink: 0;
      display: flex;
      align-items: flex-start;
      justify-content: flex-end;
      padding-top: 2px;
    }
    .header-qr img {
      height: 90px;
      width: 90px;
      object-fit: contain;
    }
    /* NABL badge — sits to the right of the QR when both are present */
    .header-nabl {
      width: 82px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 2px 0 0 6px;
      text-align: center;
    }
    .header-nabl img {
      height: 62px;
      width: auto;
      object-fit: contain;
    }
    /* Text-only fallback badge used when nabl.png isn't shipped */
    .header-nabl .nabl-text {
      border: 1.2px solid #000;
      padding: 6px 4px 5px;
      font-size: 8pt;
      font-weight: 700;
      line-height: 1.15;
      width: 78px;
      background: #fff;
    }
    .header-nabl .nabl-cert {
      display: block;
      font-family: 'Courier New', monospace;
      font-size: 7pt;
      font-weight: 700;
      margin-top: 3px;
      letter-spacing: 0.3px;
    }

    hr.divider {
      border: none;
      border-top: 2px solid #000;
      margin: 4px 0 10px;
    }

    /* ── Certificate title ── */
    .cert-title {
      text-align: center;
      font-size: 13pt;
      font-weight: 700;
      text-decoration: underline;
      letter-spacing: 1px;
      margin-bottom: 10px;
    }

    /* ── All tables ── */
    table {
      width: calc(100% - 1px);
      border-collapse: collapse;
      table-layout: fixed;
      margin-bottom: 0;
      border: 1px solid #000;
    }

    table td, table th {
      border: 1px solid #000;
      padding: 5px 7px;
      vertical-align: middle;
      font-size: 9.5pt;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .bold { font-weight: 700; }
    .center { text-align: center; }
    .italic { font-style: italic; }

    /* ── Results table ── */
    .results-table th {
      background: #f0f0f0;
      text-align: center;
      font-weight: 700;
      font-size: 9pt;
    }
    .results-table td {
      text-align: center;
      font-size: 9pt;
    }
    .results-table td.param-cell {
      font-weight: 600;
    }

    /* ── Section label above table ── */
    .section-label {
      font-weight: 700;
      font-size: 9.5pt;
      margin: 8px 0 4px;
    }

    /* ── Calibration type heading ── */
    .cal-type-heading {
      text-align: center;
      font-weight: 700;
      font-size: 10pt;
      border: 1px solid #000;
      padding: 5px;
      margin-bottom: 0;
      width: calc(100% - 1px);
    }

    /* ── Remarks box (last-page only) ── */
    .remarks-box {
      border: 1px solid #000;
      border-top: none;
      padding: 6px 10px 8px;
      width: calc(100% - 1px);
      font-size: 9.5pt;
    }
    .remarks-title {
      font-weight: 700;
      font-size: 10pt;
      margin: 0 0 4px 0;
      padding-bottom: 3px;
      border-bottom: 1px solid #000;
    }
    .remarks-list {
      margin: 0;
      padding-left: 20px;
      line-height: 1.35;
    }
    .remarks-list li { margin-bottom: 2px; }

    /* ── End of certificate marker ── */
    .end-of-cert {
      text-align: center;
      font-weight: 700;
      font-size: 10pt;
      margin-top: 8px;
      letter-spacing: 0.5px;
    }

    /* ── Signature footer ── */
    .signature-footer {
      margin-top: 10px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      width: calc(100% - 1px);
    }
    .signature-block {
      text-align: center;
      width: 40%;
    }
    .signature-img {
      height: 60px;
      width: auto;
      margin-bottom: 4px;
    }
    .stamp-block {
      text-align: center;
      width: 20%;
    }
    .stamp-img {
      height: 70px;
      width: auto;
    }
    .signature-name {
      font-weight: 700;
      font-size: 10pt;
      margin-top: 4px;
    }
    .signature-role {
      font-size: 9pt;
      border-top: 1px solid #000;
      padding-top: 4px;
      margin-top: 2px;
    }
    .doc-ref {
      text-align: right;
      font-size: 8pt;
      font-weight: 700;
      margin-top: 10px;
    }

    /* ── Watermark ── */
    .page {
      position: relative;
    }
    .watermark {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 420px;
      opacity: 0.07;
      pointer-events: none;
      z-index: 0;
    }
    .watermark img {
      width: 100%;
      height: auto;
    }
    .page > *:not(.watermark) {
      position: relative;
      z-index: 1;
    }
  </style>
</head>
<body>

<%
// ── Pre-compute result pages (row-level split) ────────────────────────────────
// Flatten every measurement row, then slice into pages of MAX_ROWS_PER_PAGE.
// Within each page chunk, rowspans are recalculated so mid-parameter splits
// continue cleanly on the next page.
var MAX_ROWS_PER_PAGE = 22;

var allParams = (typeof calibrationResults !== 'undefined' && calibrationResults) ? calibrationResults : [];

// 1. Flatten all rows
var flatRows = [];
allParams.forEach(function(param) {
  (param.ranges || []).forEach(function(range) {
    (range.rows || []).forEach(function(row) {
      flatRows.push({ paramName: param.parameter, rangeName: range.label, row: row });
    });
  });
});

// 2. Slice into page chunks
var rawPages = [];
for (var i = 0; i < flatRows.length; i += MAX_ROWS_PER_PAGE) {
  rawPages.push(flatRows.slice(i, i + MAX_ROWS_PER_PAGE));
}
if (rawPages.length === 0) rawPages.push([]);

// 3. For each chunk, annotate each flat row with within-chunk rowspan info
var resultPages = rawPages.map(function(chunk) {
  return chunk.map(function(flatRow, idx) {
    var isFirstParam = (idx === 0 || chunk[idx - 1].paramName !== flatRow.paramName);
    var isFirstRange = (idx === 0 ||
      chunk[idx - 1].paramName !== flatRow.paramName ||
      chunk[idx - 1].rangeName !== flatRow.rangeName);

    var paramRowspan = 0;
    if (isFirstParam) {
      for (var j = idx; j < chunk.length && chunk[j].paramName === flatRow.paramName; j++) paramRowspan++;
    }
    var rangeRowspan = 0;
    if (isFirstRange) {
      for (var j = idx; j < chunk.length &&
           chunk[j].paramName === flatRow.paramName &&
           chunk[j].rangeName === flatRow.rangeName; j++) rangeRowspan++;
    }

    return {
      row: flatRow.row,
      paramName: flatRow.paramName,
      rangeName: flatRow.rangeName,
      showParam: isFirstParam,
      paramRowspan: paramRowspan,
      showRange: isFirstRange,
      rangeRowspan: rangeRowspan
    };
  });
});

var computedTotalPages = 1 + resultPages.length;
%>

<!-- ═══════════════════════════════════════════════════════════════ PAGE 1 -->
<div class="page">

  <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
  <div class="watermark"><img src="<%= logoUrl %>" alt="" /></div>
  <% } %>

  <div class="header">
    <div class="header-logo">
      <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="Josts Logo" />
      <% } %>
    </div>
    <div class="header-company">
      <div class="company-name">Jost&#8217;s Engineering Company Limited</div>
      <div class="company-meta">
        <%= typeof letterHeadAddress !== 'undefined' && letterHeadAddress ? letterHeadAddress : '19, British Indian Street, Kolkata 700 069, West Bengal, India.' %><br/>
        CIN: L28100MH1907PLC000252, &nbsp; Tel.: +91 33 2242 9510, &nbsp; Fax: +91 33 2248 0861<br/>
        <span class="meta-row">
          <span>Email: salescal@josts.in</span>
          <span>Website: www.josts.com</span>
        </span>
        (Registered Office: Great Social Building, 60 Sir Phirozeshah Mehta Road, Mumbai 400 001)
      </div>
    </div>
    <% if (typeof qrUrl !== 'undefined' && qrUrl) { %>
      <div class="header-qr">
        <img src="<%= qrUrl %>" alt="Report QR Code" />
      </div>
    <% } %>
    <% if (typeof showNabl !== 'undefined' && showNabl) { %>
      <div class="header-nabl">
        <% if (typeof nablBadgeUrl !== 'undefined' && nablBadgeUrl) { %>
          <img src="<%= nablBadgeUrl %>" alt="NABL Certified" />
          <% if (typeof nablCertNo !== 'undefined' && nablCertNo) { %>
            <span class="nabl-cert"><%= nablCertNo %></span>
          <% } %>
        <% } else { %>
          <div class="nabl-text">
            NABL<br/>ACCREDITED
            <% if (typeof nablCertNo !== 'undefined' && nablCertNo) { %>
              <span class="nabl-cert"><%= nablCertNo %></span>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <hr class="divider" />

  <div class="page-body">

  <div class="cert-title">CALIBRATION CERTIFICATE</div>

  <table>
    <tr>
      <td colspan="3" class="center bold" style="width:55%">Certificate No.</td>
      <td colspan="2" class="center bold" style="width:30%">Certificate Issue Date</td>
      <td class="center bold" style="width:15%">Page<br/>Number</td>
    </tr>
    <tr>
      <td colspan="3" class="center"><%= typeof certificateNo !== 'undefined' ? certificateNo : '' %></td>
      <td colspan="2" class="center"><%= typeof certificateIssueDate !== 'undefined' ? certificateIssueDate : '' %></td>
      <td class="center">1 of <%= computedTotalPages %></td>
    </tr>
  </table>

  <table>
    <tr>
      <td class="bold center" style="width:15%">DUC<br/>Received<br/>Date</td>
      <td class="bold center" style="width:16%">Date of<br/>Calibration</td>
      <td class="bold center" style="width:16%">Valid<br/>Up To</td>
      <td class="bold center" colspan="3">Customer Reference No.</td>
    </tr>
    <tr>
      <td class="center"><%= typeof ducReceivedDate !== 'undefined' ? ducReceivedDate : '' %></td>
      <td class="center"><%= typeof dateOfCalibration !== 'undefined' ? dateOfCalibration : '' %></td>
      <td class="center"><%= typeof validUpto !== 'undefined' ? validUpto : '' %></td>
      <td class="center" colspan="3"><%= typeof customerReferenceNo !== 'undefined' ? customerReferenceNo : '' %></td>
    </tr>
  </table>

  <table>
    <tr>
      <td class="bold" style="width:30%">Name &amp; Address of the Customer :</td>
      <td style="white-space:pre-line"><% if (typeof customerName !== 'undefined' && customerName) { %><strong><%= customerName %></strong><br/><% } %><%= typeof customerAddress !== 'undefined' ? customerAddress : '' %></td>
    </tr>
  </table>

  <table>
    <tr>
      <td colspan="7" class="bold center">Details of the DUC to be Calibrated</td>
    </tr>
    <tr>
      <td class="bold center" colspan="2">Name of DUC</td>
      <td class="bold center">Identification /<br/>Serial Number</td>
      <td class="bold center">Make</td>
      <td class="bold center">Model</td>
      <td class="bold center">Range</td>
      <td class="bold center">Least Count</td>
    </tr>
    <tr>
      <td colspan="2" class="center"><%= typeof ducName !== 'undefined' ? ducName : '' %></td>
      <td class="center"><%= typeof ducSerialNo !== 'undefined' ? ducSerialNo : '' %></td>
      <td class="center"><%= typeof ducMake !== 'undefined' ? ducMake : '' %></td>
      <td class="center"><%= typeof ducModel !== 'undefined' ? ducModel : '' %></td>
      <td class="center"><%= typeof ducRange !== 'undefined' ? ducRange : 'As Per Instrument Spec.' %></td>
      <td class="center"><%= typeof ducLeastCount !== 'undefined' ? ducLeastCount : 'Refer Cal Results' %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Accuracy :</td>
      <td colspan="5"><%= typeof accuracy !== 'undefined' ? accuracy : "As per Manufacturer's Specification" %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Condition of Item :</td>
      <td colspan="5"><%= typeof conditionOfItem !== 'undefined' ? conditionOfItem : 'Satisfactory' %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Location of Calibration:</td>
      <td colspan="5"><%= typeof locationOfCalibration !== 'undefined' ? locationOfCalibration : 'At Site' %></td>
    </tr>
  </table>

  <table>
    <tr>
      <td colspan="6" class="bold center">Environmental Condition</td>
    </tr>
    <tr>
      <td rowspan="2" class="bold center" style="width:18%">Recommended</td>
      <td style="width:14%">Temp</td>
      <td style="width:14%"><%= typeof recommendedTemp !== 'undefined' ? recommendedTemp : '25±4 °C' %></td>
      <td rowspan="2" class="bold center" style="width:12%">During<br/>Calibration</td>
      <td style="width:14%">Temp</td>
      <td><%= typeof duringCalibrationTemp !== 'undefined' ? duringCalibrationTemp : '' %></td>
    </tr>
    <tr>
      <td>Humidity</td>
      <td><%= typeof recommendedHumidity !== 'undefined' ? recommendedHumidity : '55±15 %' %></td>
      <td>Humidity</td>
      <td><%= typeof duringCalibrationHumidity !== 'undefined' ? duringCalibrationHumidity : '' %></td>
    </tr>
    <tr>
      <td class="bold" colspan="2">Calibration Procedure :</td>
      <td colspan="2"><%= typeof calibrationProcedure !== 'undefined' ? calibrationProcedure : '' %></td>
      <td class="bold">Method of Calibration :</td>
      <td><%= typeof methodOfCalibration !== 'undefined' ? methodOfCalibration : 'Direct Method' %></td>
    </tr>
  </table>

  <table>
    <tr>
      <td colspan="4" class="italic">
        <strong>Description of Standard (s) :</strong>
        <%= typeof descriptionOfStandards !== 'undefined' ? descriptionOfStandards : 'Traceable to National / International Standards' %>
      </td>
    </tr>
  </table>

  <table>
    <tr>
      <td class="bold center" style="width:28%">Reference Standard Details</td>
      <td class="bold center" style="width:18%">Make/Model</td>
      <td class="bold center" style="width:16%">Valid upto</td>
      <td class="bold center">Traceability Certificate No.</td>
    </tr>
    <% if (typeof referenceStandards !== 'undefined' && referenceStandards && referenceStandards.length) { %>
      <% referenceStandards.forEach(function(std) { %>
        <tr>
          <td>Name : <%= std.name || '' %></td>
          <td class="center" style="border-bottom: hidden;"><%= std.makeModel || '' %></td>
          <td class="center" style="border-bottom: hidden;"><%= std.validUpto || '' %></td>
          <td class="center" style="border-bottom: hidden;"><%= std.traceabilityCertNo || '' %></td>
        </tr>
        <tr>
          <td>ID No : <%= std.idNo || '' %></td>
          <td style="border-top: hidden; border-bottom: hidden;"></td>
          <td style="border-top: hidden; border-bottom: hidden;"></td>
          <td style="border-top: hidden; border-bottom: hidden;"></td>
        </tr>
        <tr>
          <td>Sr No : <%= std.srNo || '' %></td>
          <td style="border-top: hidden;"></td>
          <td style="border-top: hidden;"></td>
          <td style="border-top: hidden;"></td>
        </tr>
      <% }); %>
    <% } else { %>
      <tr>
        <td>Name :</td>
        <td class="center" style="border-bottom: hidden;"></td>
        <td class="center" style="border-bottom: hidden;"></td>
        <td class="center" style="border-bottom: hidden;"></td>
      </tr>
      <tr>
        <td>ID No :</td>
        <td style="border-top: hidden; border-bottom: hidden;"></td>
        <td style="border-top: hidden; border-bottom: hidden;"></td>
        <td style="border-top: hidden; border-bottom: hidden;"></td>
      </tr>
      <tr>
        <td>Sr No :</td>
        <td style="border-top: hidden;"></td>
        <td style="border-top: hidden;"></td>
        <td style="border-top: hidden;"></td>
      </tr>
    <% } %>
  </table>

  </div><!-- end .page-body -->

  <div class="signature-footer">
    <div class="signature-block">
      <% if (typeof calibratedBySignatureUrl !== 'undefined' && calibratedBySignatureUrl) { %>
        <img class="signature-img" src="<%= calibratedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof calibratedByName !== 'undefined' ? calibratedByName : '' %></div>
      <div class="signature-role">Calibrated By : <%= typeof calibratedByRole !== 'undefined' ? calibratedByRole : 'Calibration Engineer' %></div>
    </div>
    <div class="stamp-block">
      <% if (typeof stampUrl !== 'undefined' && stampUrl) { %>
        <img class="stamp-img" src="<%= stampUrl %>" alt="Company Stamp" />
      <% } else { %>
        <div style="height:70px;"></div>
      <% } %>
    </div>
    <div class="signature-block">
      <% if (typeof approvedBySignatureUrl !== 'undefined' && approvedBySignatureUrl) { %>
        <img class="signature-img" src="<%= approvedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof approvedByName !== 'undefined' ? approvedByName : '' %></div>
      <div class="signature-role">Approved By : <%= typeof approvedByRole !== 'undefined' ? approvedByRole : 'Technical/Quality Manager' %></div>
    </div>
  </div>

</div>
<!-- ══════════════════════════════════ END PAGE 1 ══════════════════════════════ -->


<!-- ══════════════════════════════════ RESULTS PAGES ═════════════════════════ -->
<% resultPages.forEach(function(pageParams, pageIdx) { %>
<div class="page">

  <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
  <div class="watermark"><img src="<%= logoUrl %>" alt="" /></div>
  <% } %>

  <div class="header">
    <div class="header-logo">
      <% if (typeof logoUrl !== 'undefined' && logoUrl) { %>
        <img src="<%= logoUrl %>" alt="Josts Logo" />
      <% } %>
    </div>
    <div class="header-company">
      <div class="company-name">Jost&#8217;s Engineering Company Limited</div>
      <div class="company-meta">
        <%= typeof letterHeadAddress !== 'undefined' && letterHeadAddress ? letterHeadAddress : '19, British Indian Street, Kolkata 700 069, West Bengal, India.' %><br/>
        CIN: L28100MH1907PLC000252, &nbsp; Tel.: +91 33 2242 9510, &nbsp; Fax: +91 33 2248 0861<br/>
        <span class="meta-row">
          <span>Email: salescal@josts.in</span>
          <span>Website: www.josts.com</span>
        </span>
        (Registered Office: Great Social Building, 60 Sir Phirozeshah Mehta Road, Mumbai 400 001)
      </div>
    </div>
    <% if (typeof qrUrl !== 'undefined' && qrUrl) { %>
      <div class="header-qr">
        <img src="<%= qrUrl %>" alt="Report QR Code" />
      </div>
    <% } %>
    <% if (typeof showNabl !== 'undefined' && showNabl) { %>
      <div class="header-nabl">
        <% if (typeof nablBadgeUrl !== 'undefined' && nablBadgeUrl) { %>
          <img src="<%= nablBadgeUrl %>" alt="NABL Certified" />
          <% if (typeof nablCertNo !== 'undefined' && nablCertNo) { %>
            <span class="nabl-cert"><%= nablCertNo %></span>
          <% } %>
        <% } else { %>
          <div class="nabl-text">
            NABL<br/>ACCREDITED
            <% if (typeof nablCertNo !== 'undefined' && nablCertNo) { %>
              <span class="nabl-cert"><%= nablCertNo %></span>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <hr class="divider" />

  <div class="page-body">

  <table>
    <tr>
      <td colspan="3" class="center bold" style="width:55%">Certificate No.</td>
      <td colspan="2" class="center bold" style="width:30%">Certificate Issue Date</td>
      <td class="center bold" style="width:15%">Page<br/>Number</td>
    </tr>
    <tr>
      <td colspan="3" class="center"><%= typeof certificateNo !== 'undefined' ? certificateNo : '' %></td>
      <td colspan="2" class="center"><%= typeof certificateIssueDate !== 'undefined' ? certificateIssueDate : '' %></td>
      <td class="center"><%= pageIdx + 2 %> of <%= computedTotalPages %></td>
    </tr>
  </table>

  <div class="section-label">Calibration Results :</div>

  <div class="cal-type-heading">
    <%= typeof calibrationType !== 'undefined' ? calibrationType : 'Electro - Technical Calibration' %>
  </div>

  <table class="results-table">
    <thead>
      <tr>
        <th rowspan="2" style="width:16%">Parameter</th>
        <th rowspan="2" style="width:14%">Range</th>
        <th colspan="2">STANDARD</th>
        <th colspan="2">DUC</th>
        <th colspan="2">ERROR</th>
        <th rowspan="2" style="width:14%">Expanded<br/>Uncertainty (± %)</th>
      </tr>
      <tr>
        <th style="width:8%">Value</th>
        <th style="width:6%">Unit</th>
        <th style="width:8%">Value</th>
        <th style="width:6%">Unit</th>
        <th style="width:8%">Value</th>
        <th style="width:6%">Unit</th>
      </tr>
    </thead>
    <tbody>
      <% if (pageParams.length > 0) { %>
        <% pageParams.forEach(function(r) { %>
          <tr>
            <% if (r.showParam) { %>
              <td class="param-cell center" rowspan="<%= r.paramRowspan %>"><%= r.paramName || '' %></td>
            <% } %>
            <% if (r.showRange) { %>
              <td class="center" rowspan="<%= r.rangeRowspan %>"><%= r.rangeName || '' %></td>
            <% } %>
            <td class="center"><%= r.row.standardValue || '' %></td>
            <td class="center"><%= r.row.standardUnit  || '' %></td>
            <td class="center"><%= r.row.ducValue       || '' %></td>
            <td class="center"><%= r.row.ducUnit        || '' %></td>
            <td class="center"><%= r.row.errorValue     || '' %></td>
            <td class="center"><%= r.row.errorUnit      || '' %></td>
            <td class="center"><%= r.row.expandedUncertainty || '' %></td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="9" class="center" style="color:#888;font-style:italic">No calibration results provided</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <% if (pageIdx === resultPages.length - 1 && Array.isArray(remarks) && remarks.length > 0) { %>
    <div class="remarks-box">
      <div class="remarks-title">Remarks :</div>
      <ol class="remarks-list">
        <% remarks.forEach(function(r) { %>
          <li><%= r %></li>
        <% }); %>
      </ol>
    </div>
  <% } %>

  </div><!-- end .page-body -->

  <div class="signature-footer">
    <div class="signature-block">
      <% if (typeof calibratedBySignatureUrl !== 'undefined' && calibratedBySignatureUrl) { %>
        <img class="signature-img" src="<%= calibratedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof calibratedByName !== 'undefined' ? calibratedByName : '' %></div>
      <div class="signature-role">Calibrated By : <%= typeof calibratedByRole !== 'undefined' ? calibratedByRole : 'Calibration Engineer' %></div>
    </div>
    <div class="stamp-block">
      <% if (typeof stampUrl !== 'undefined' && stampUrl) { %>
        <img class="stamp-img" src="<%= stampUrl %>" alt="Company Stamp" />
      <% } else { %>
        <div style="height:70px;"></div>
      <% } %>
    </div>
    <div class="signature-block">
      <% if (typeof approvedBySignatureUrl !== 'undefined' && approvedBySignatureUrl) { %>
        <img class="signature-img" src="<%= approvedBySignatureUrl %>" alt="Signature" />
      <% } else { %>
        <div style="height:60px;"></div>
      <% } %>
      <div class="signature-name"><%= typeof approvedByName !== 'undefined' ? approvedByName : '' %></div>
      <div class="signature-role">Approved By : <%= typeof approvedByRole !== 'undefined' ? approvedByRole : 'Technical/Quality Manager' %></div>
    </div>
  </div>
  <% if (pageIdx === resultPages.length - 1) { %>
    <div class="end-of-cert">***End of Calibration Certificate***</div>
  <% } %>
  <div class="doc-ref"><%= typeof docRef !== 'undefined' ? docRef : 'JECL/KOL/LAB/43B' %></div>

</div>
<% }); %>
<!-- ══════════════════════════════════ END RESULTS PAGES ══════════════════════ -->

</body>
</html>
